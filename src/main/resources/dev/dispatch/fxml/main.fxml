<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<BorderPane
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="dev.dispatch.ui.MainController"
    styleClass="app-root">

  <top>
    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT" minHeight="38" maxHeight="38">

      <!-- macOS: traffic-light circles on the left -->
      <HBox fx:id="trafficLights" spacing="7" alignment="CENTER">
        <padding><Insets top="0" right="0" bottom="0" left="14"/></padding>
        <Label styleClass="traffic-light traffic-light-close" onMouseClicked="#onClose"/>
        <Label styleClass="traffic-light traffic-light-min"   onMouseClicked="#onMinimize"/>
        <Label styleClass="traffic-light traffic-light-max"   onMouseClicked="#onMaximize"/>
      </HBox>

      <!-- Centred title -->
      <Region HBox.hgrow="ALWAYS"/>
      <Label text="DISPATCH" styleClass="title-bar-title"/>
      <Region HBox.hgrow="ALWAYS"/>

      <!-- Windows / Linux: &#x2212; &#x25A1; &#x2715; -->
      <HBox fx:id="winControls" spacing="0" alignment="CENTER">
        <Button fx:id="winMinBtn"   text="&#x2212;" styleClass="win-btn"           onAction="#onMinimize"/>
        <Button fx:id="winMaxBtn"   text="&#x25A1;" styleClass="win-btn"           onAction="#onMaximize"/>
        <Button fx:id="winCloseBtn" text="&#x2715;" styleClass="win-btn close-btn" onAction="#onClose"/>
      </HBox>

    </HBox>
  </top>

  <center>
    <SplitPane fx:id="mainSplitPane"
               dividerPositions="0.17"
               orientation="HORIZONTAL">
      <fx:include source="host-list.fxml" fx:id="hostList"/>

      <StackPane fx:id="terminalArea" styleClass="main-content">
        <TabPane fx:id="sessionTabPane" styleClass="session-tabs" tabClosingPolicy="ALL_TABS"/>
        <Label fx:id="emptyStateLabel"
               text="Select a host and double-click to connect"
               styleClass="empty-state-label"/>
        <!-- Toolbar overlaid at top-right; transparent HBox so tabs beneath stay visible.
             pickOnBounds=false passes mouse events through empty space to the tabs. -->
        <HBox fx:id="tabToolbar" styleClass="tab-toolbar"
              StackPane.alignment="TOP_RIGHT" pickOnBounds="false"
              alignment="CENTER_RIGHT" spacing="2">
          <padding><Insets top="0" right="6" bottom="0" left="6"/></padding>
          <Button fx:id="dockerToggleBtn" styleClass="tab-toolbar-btn" onAction="#onDockerToggle"/>
        </HBox>
      </StackPane>
    </SplitPane>
  </center>

  <bottom>
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">
      <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
      <Region HBox.hgrow="ALWAYS"/>
      <Label text="Java 21  ·  Virtual Threads" styleClass="status-item"/>
      <Label text="v0.1.0" styleClass="status-item"/>
    </HBox>
  </bottom>

</BorderPane>
