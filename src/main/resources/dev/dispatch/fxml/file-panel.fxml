<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="dev.dispatch.ui.filemanager.FilePanelController"
    styleClass="file-panel"
    VBox.vgrow="ALWAYS"
    HBox.hgrow="ALWAYS">

  <!-- Header: session name + home + refresh -->
  <HBox styleClass="file-panel-header" alignment="CENTER_LEFT" spacing="4">
    <padding><Insets top="5" right="8" bottom="5" left="8"/></padding>
    <Label fx:id="titleLabel" styleClass="file-panel-title" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
  </HBox>

  <!-- Editable path bar -->
  <TextField fx:id="pathField" styleClass="file-panel-path" onAction="#onPathEnter" promptText="/"/>

  <!-- File listing -->
  <TableView fx:id="fileTable" VBox.vgrow="ALWAYS" styleClass="file-table">
    <columns>
      <TableColumn fx:id="nameColumn"  text="Nazwa"           prefWidth="210" minWidth="120"/>
      <TableColumn fx:id="sizeColumn"  text="Rozmiar"         prefWidth="90"  minWidth="70"  style="-fx-alignment: CENTER_RIGHT;"/>
      <TableColumn fx:id="dateColumn"  text="Data modyfikacji" prefWidth="150" minWidth="100"/>
    </columns>
    <placeholder><Label text="(pusty katalog)" styleClass="file-panel-empty"/></placeholder>
  </TableView>

  <!-- Status bar -->
  <Label fx:id="statusLabel" styleClass="file-panel-status"/>

</VBox>
