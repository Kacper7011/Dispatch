<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="dev.dispatch.ui.filemanager.FilePanelController"
    styleClass="file-panel"
    VBox.vgrow="ALWAYS"
    HBox.hgrow="ALWAYS">

  <!-- Header: session switcher flush-left -->
  <HBox styleClass="file-panel-header" alignment="CENTER_LEFT" spacing="0">
    <padding><Insets top="5" right="8" bottom="5" left="8"/></padding>
    <MenuButton fx:id="sessionBtn" styleClass="file-panel-session-btn" text="Switch session" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
  </HBox>

  <!-- Editable path bar -->
  <TextField fx:id="pathField" styleClass="file-panel-path" onAction="#onPathEnter" promptText="/"/>

  <!-- Filter bar -->
  <HBox styleClass="file-filter-bar" alignment="CENTER_LEFT" spacing="4">
    <padding><Insets top="3" right="6" bottom="3" left="6"/></padding>
    <ToggleButton fx:id="hideDotfilesBtn" styleClass="file-filter-toggle" text=".*" focusTraversable="false"/>
    <ToggleButton fx:id="dirsOnlyBtn"     styleClass="file-filter-toggle" text="dir" focusTraversable="false"/>
    <TextField fx:id="filterField" styleClass="file-filter-field" promptText="filter…" HBox.hgrow="ALWAYS" focusTraversable="true"/>
    <Button fx:id="clearFilterBtn" styleClass="file-filter-clear" text="×" focusTraversable="false"/>
  </HBox>

  <!-- File listing -->
  <TableView fx:id="fileTable" VBox.vgrow="ALWAYS" styleClass="file-table">
    <columns>
      <TableColumn fx:id="nameColumn"  text="Name"            prefWidth="210" minWidth="120"/>
      <TableColumn fx:id="sizeColumn"  text="Size"            prefWidth="90"  minWidth="70"  style="-fx-alignment: CENTER_RIGHT;"/>
      <TableColumn fx:id="dateColumn"  text="Date modified"   prefWidth="150" minWidth="100"/>
    </columns>
    <placeholder><Label text="(empty directory)" styleClass="file-panel-empty"/></placeholder>
  </TableView>

  <!-- Status bar -->
  <Label fx:id="statusLabel" styleClass="file-panel-status"/>

</VBox>
