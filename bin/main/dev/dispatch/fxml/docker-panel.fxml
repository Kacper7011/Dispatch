<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="dev.dispatch.ui.docker.DockerPanelController"
    prefWidth="280"
    styleClass="docker-panel">

  <!-- Header toolbar -->
  <HBox styleClass="docker-toolbar" alignment="CENTER_LEFT" spacing="8">
    <padding><Insets top="8" right="10" bottom="8" left="14"/></padding>
    <Label text="DOCKER" styleClass="docker-panel-title"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="⟳" onAction="#onRefresh" styleClass="docker-toolbar-btn"/>
    <Button fx:id="closePanelBtn" text="✕" styleClass="docker-toolbar-btn"/>
  </HBox>

  <!-- Scrollable tree content — sections are added programmatically by the controller -->
  <ScrollPane
      VBox.vgrow="ALWAYS"
      fitToWidth="true"
      hbarPolicy="NEVER"
      styleClass="docker-scroll">
    <VBox fx:id="contentBox" styleClass="docker-content"/>
  </ScrollPane>

  <!-- Status bar -->
  <Label fx:id="statusLabel" styleClass="docker-status-label">
    <padding><Insets top="4" right="14" bottom="4" left="14"/></padding>
  </Label>

</VBox>
